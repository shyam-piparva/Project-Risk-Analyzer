# =============================================================================
# AI Project Risk Analyzer - Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# All variables must be prefixed with VITE_ to be exposed to the client
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API base URL
VITE_API_URL=http://localhost:3000/api
VITE_API_VERSION=v1

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features (true/false)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Application name and version
VITE_APP_NAME=AI Project Risk Analyzer
VITE_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# Current environment (development, staging, production)
VITE_ENV=development

