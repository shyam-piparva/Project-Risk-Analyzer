{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for Project Risk Analyzer",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "migrate:redo": "node-pg-migrate redo",
    "migrate:script": "tsx scripts/run-migrations.ts",
    "seed": "tsx scripts/seed-database.ts",
    "seed:users": "tsx scripts/seed-database.ts users",
    "seed:projects": "tsx scripts/seed-database.ts projects",
    "seed:risks": "tsx scripts/seed-database.ts risks",
    "seed:clean": "tsx scripts/seed-database.ts clean"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "axios": "^1.15.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "express": "^4.18.2",
    "joi": "^17.9.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "uuid": "^13.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.4.0",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^7.2.0",
    "fast-check": "^4.6.0",
    "jest": "^29.6.0",
    "node-pg-migrate": "^8.0.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.1.0"
  }
}
